{% extends 'admin/layout.html.twig' %}
{% block sidebar_active_categories %}active{% endblock %}
{% block title %}Catégories — Admin{% endblock %}

{% block admin_content %}
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
    <h1 style="font-size:1.6rem;font-weight:800">🏷️ Catégories</h1>
    <a href="{{ path('app_admin_categorie_new') }}" class="btn btn-primary">+ Nouvelle catégorie</a>
</div>

<div class="admin-card">
    <table class="table">
        <thead>
            <tr><th>Nom</th><th>Description</th><th>Nb produits</th><th>Actions</th></tr>
        </thead>
        <tbody>
        {% for cat in categories %}
            <tr>
                <td><strong>{{ cat.nom }}</strong></td>
                <td style="color:var(--text-light);font-size:.88rem">{{ cat.description }}</td>
                <td>{{ cat.produits|length }}</td>
                <td>
                    <a href="{{ path('app_admin_categorie_edit', {id: cat.id}) }}" class="btn btn-outline btn-sm">✏️ Modifier</a>
                    <form method="post" action="{{ path('app_admin_categorie_delete', {id: cat.id}) }}"
                          style="display:inline" onsubmit="return confirm('Supprimer cette catégorie ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_cat_' ~ cat.id) }}">
                        <button class="btn btn-danger btn-sm">🗑️</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="4" style="text-align:center;padding:2rem;color:var(--text-light)">Aucune catégorie.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
