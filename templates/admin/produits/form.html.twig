{% extends 'admin/layout.html.twig' %}
{% block sidebar_active_produits %}active{% endblock %}
{% block title %}{{ titre }} — Admin{% endblock %}

{% block admin_content %}
<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
    <a href="{{ path('app_admin_produits') }}" class="btn btn-outline btn-sm">← Retour</a>
    <h1 style="font-size:1.4rem;font-weight:800">{{ titre }}</h1>
</div>

{% if errors|length > 0 %}
    <div style="background:#f8d7da;color:#721c24;border-radius:10px;padding:1rem;margin-bottom:1.2rem">
        <ul style="margin-left:1rem">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
    </div>
{% endif %}

<div class="admin-card" style="padding:1.5rem;max-width:700px">
    <form method="post">
        <div style="display:grid;gap:1.1rem">
            <div>
                <label style="display:block;font-weight:600;margin-bottom:.35rem">Nom du produit *</label>
                <input type="text" name="nom" class="form-control"
                       value="{{ produit ? produit.nom : '' }}" required placeholder="ex: Poulet Frit">
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                <div>
                    <label style="display:block;font-weight:600;margin-bottom:.35rem">Prix (€) *</label>
                    <input type="number" name="prix" step="0.01" min="0" class="form-control"
                           value="{{ produit ? produit.prix : '' }}" required placeholder="9.90">
                </div>
                <div>
                    <label style="display:block;font-weight:600;margin-bottom:.35rem">Catégorie *</label>
                    <select name="categorie_id" class="form-control" required>
                        <option value="">-- Choisir --</option>
                        {% for cat in categories %}
                            <option value="{{ cat.id }}" {{ produit and produit.categorie.id == cat.id ? 'selected' : '' }}>
                                {{ cat.nom }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div>
                <label style="display:block;font-weight:600;margin-bottom:.35rem">Description</label>
                <textarea name="description" class="form-control" rows="3" placeholder="Description du plat...">{{ produit ? produit.description : '' }}</textarea>
            </div>
            <div>
                <label style="display:block;font-weight:600;margin-bottom:.5rem">Ingrédients disponibles</label>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.4rem;max-height:220px;overflow:auto;background:#f8f9fa;border:2px solid var(--border);border-radius:10px;padding:.8rem">
                    {% for ing in ingredients %}
                        <label style="display:flex;align-items:center;gap:.5rem;font-size:.88rem;cursor:pointer">
                            <input type="checkbox" name="ingredients[]" value="{{ ing.id }}"
                                   {{ produit and ing in produit.ingredients ? 'checked' : '' }}>
                            {{ ing.nom }}
                            {% if ing.prixSupplement %}
                                <span style="color:var(--primary);font-size:.78rem">(+{{ ing.prixSupplement }} €)</span>
                            {% endif %}
                        </label>
                    {% endfor %}
                </div>
            </div>
            <div style="display:flex;gap:.8rem;margin-top:.5rem">
                <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                <a href="{{ path('app_admin_produits') }}" class="btn btn-outline">Annuler</a>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-control {
        width: 100%; padding: .72rem 1rem; border: 2px solid var(--border);
        border-radius: 10px; font-size: .92rem; transition: var(--transition);
        font-family: inherit; color: var(--text); background: #fff;
    }
    .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(231,76,60,.15); }
</style>
{% endblock %}
