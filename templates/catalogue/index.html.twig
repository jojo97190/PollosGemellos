{% extends 'base.html.twig' %}

{% block title %}Catalogue — Pollos Gemelos{% endblock %}

{% block stylesheets %}
<style>
    /* ===== HEADER CATALOGUE ===== */
    .cat-header {
        background: linear-gradient(135deg, var(--navy) 0%, #c0392b 100%);
        color: #fff; padding: 2.5rem 1.5rem; text-align: center;
    }
    .cat-header h1 { font-size: 2rem; font-weight: 800; margin-bottom: .4rem; }
    .cat-header p { opacity: .8; font-size: .95rem; }

    /* ===== FILTERS ===== */
    .filters { padding: 1.5rem 1.5rem 0; max-width: 1200px; margin: 0 auto; }
    .filters-label { font-size: .82rem; font-weight: 600; color: var(--text-light); text-transform: uppercase; letter-spacing: .06em; margin-bottom: .6rem; }
    .filter-pills { display: flex; flex-wrap: wrap; gap: .5rem; }
    .pill {
        padding: .45rem 1.1rem; border-radius: 20px; font-size: .85rem; font-weight: 600;
        text-decoration: none; border: 2px solid transparent; transition: var(--transition);
    }
    .pill-inactive { background: #fff; color: var(--text-light); border-color: var(--border); }
    .pill-inactive:hover { border-color: var(--primary); color: var(--primary); }
    .pill-active { background: var(--primary); color: #fff; border-color: var(--primary); }

    @media (max-width: 768px) {
        .cat-header { padding: 1.75rem 1rem; }
        .cat-header h1 { font-size: 1.5rem; }
        .filters { padding: 1rem 1rem 0; }
        .catalogue { padding: 0 1rem 2rem; margin-top: 1.25rem; }
        .products-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
    }
    @media (max-width: 480px) {
        .products-grid { grid-template-columns: 1fr; }
        .pill { padding: .38rem .85rem; font-size: .8rem; }
    }

    /* ===== PRODUCT GRID ===== */
    .catalogue { max-width: 1200px; margin: 2rem auto; padding: 0 1.5rem 3rem; }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    .card {
        background: var(--card-bg); border-radius: var(--radius);
        box-shadow: var(--shadow); overflow: hidden;
        transition: var(--transition); display: flex; flex-direction: column;
    }
    .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); }
    .card-img {
        width: 100%; height: 180px;
        background: linear-gradient(135deg, #f5e6d3, #fad7a0);
        display: flex; align-items: center; justify-content: center;
        font-size: 4rem;
    }
    .card-body { padding: 1.2rem; flex: 1; display: flex; flex-direction: column; gap: .5rem; }
    .card-badge {
        display: inline-block; font-size: .7rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .05em; padding: .25rem .6rem; border-radius: 20px;
        background: #fff3cd; color: #856404; width: fit-content;
    }
    .card-title { font-size: 1.05rem; font-weight: 700; color: var(--text); }
    .card-desc { font-size: .85rem; color: var(--text-light); flex: 1; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: .75rem; }
    .price { font-size: 1.3rem; font-weight: 800; color: var(--primary); }

    /* ===== EMPTY STATE ===== */
    .empty { text-align: center; padding: 4rem 2rem; color: var(--text-light); }
    .empty .emoji { font-size: 4rem; display: block; margin-bottom: 1rem; }
</style>
{% endblock %}

{% block body %}
<div class="cat-header">
    <h1>🍽️ Notre Catalogue</h1>
    <p>Découvrez tous nos plats faits maison, personnalisables à votre goût.</p>
</div>

<div class="filters">
    <div class="filters-label">Filtrer par catégorie</div>
    <div class="filter-pills">
        <a href="{{ path('app_catalogue') }}"
           class="pill {{ categorieActive == 0 ? 'pill-active' : 'pill-inactive' }}">
            Tous les plats
        </a>
        {% set cat_icons = {'Burgers':'🍔','Pizzas':'🍕','Salades':'🥗','Desserts':'🍮','Boissons':'🥤','Poulet':'🍗','Accompagnements':'🍟'} %}
        {% for categorie in categories %}
            <a href="{{ path('app_catalogue', { categorie: categorie.id }) }}"
               class="pill {{ categorieActive == categorie.id ? 'pill-active' : 'pill-inactive' }}">
                {{ cat_icons[categorie.nom] ?? '🍽️' }} {{ categorie.nom }}
            </a>
        {% endfor %}
    </div>
</div>

<section class="catalogue">
    {% if produits is empty %}
        <div class="empty">
            <span class="emoji">🍽️</span>
            <p>Aucun produit dans cette catégorie pour le moment.</p>
            <a href="{{ path('app_catalogue') }}" class="btn btn-primary" style="margin-top:1rem">Voir tout le catalogue</a>
        </div>
    {% else %}
        <div class="products-grid">
            {% set icons = {'Burgers':'🍔','Pizzas':'🍕','Salades':'🥗','Desserts':'🍮','Boissons':'🥤','Poulet':'🍗','Accompagnements':'🍟'} %}
            {% for produit in produits %}
                <div class="card">
                    <div class="card-img">
                        {% if produit.image %}
                            <img src="{{ produit.image }}" alt="{{ produit.nom }}" style="width:100%;height:100%;object-fit:cover;">
                        {% else %}
                            {{ icons[produit.categorie.nom] ?? '🍽️' }}
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <span class="card-badge">{{ produit.categorie.nom }}</span>
                        <div class="card-title">{{ produit.nom }}</div>
                        {% if produit.description %}
                            <div class="card-desc">{{ produit.description|u.truncate(90, '…') }}</div>
                        {% endif %}
                        <div class="card-footer">
                            <span class="price">{{ produit.prix|number_format(2, ',', ' ') }} €</span>
                            <a href="{{ path('app_produit_show', { id: produit.id }) }}" class="btn btn-primary btn-sm">
                                Personnaliser →
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</section>
{% endblock %}
